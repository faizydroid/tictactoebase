# Copy this file to .env.local and fill in your values

# Contract address after deployment
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Your wallet private key (NEVER commit this file!)
# Get from MetaMask: Account Details > Export Private Key
PRIVATE_KEY=0x3b6e46e9afcfead83cd59fc3a55c2a873218732751ba5cde5d42a115d0b460a2

# BaseScan API Key (optional, for contract verification)
# Get from: https://basescan.org/myapikey
BASESCAN_API_KEY=

# Network Configuration
# For Base Mainnet: use "base"
# For Base Sepolia Testnet: use "baseSepolia"
NEXT_PUBLIC_NETWORK=baseSepolia

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key


# WalletConnect Project ID
# Get from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
