# STEP 1: Get your private key from MetaMask
# (Account Details > Export Private Key)
# Paste it below WITHOUT the 0x prefix

PRIVATE_KEY=

# STEP 2: After deployment, paste your contract address here
NEXT_PUBLIC_CONTRACT_ADDRESS=

# STEP 3: Set the network (base for mainnet, baseSepolia for testnet)
NEXT_PUBLIC_NETWORK=base

# Optional: Custom RPC URL (leave empty to use default)
BASE_RPC_URL=

# Optional: BaseScan API key for contract verification
BASESCAN_API_KEY=